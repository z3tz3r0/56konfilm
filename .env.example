# --- 🟢 PUBLIC CONFIGURATION (Prefix with NEXT_PUBLIC_) ---
# These are exposed to the browser.
NEXT_PUBLIC_SANITY_PROJECT_ID="project_id"
NEXT_PUBLIC_SANITY_DATASET="production" # production | development
NEXT_PUBLIC_SANITY_API_VERSION="2025-08-12"
NEXT_PUBLIC_SITE_URL=
DEFAULT_SITE_MODE="commercial" # commercial | wedding

# --- 🔵 SANITY CMS CONFIGURATION (Server-side) ---
SANITY_API_TOKEN="api_secret"
SANITY_REVALIDATE_SECRET="webhook_secret"
SANITY_CMS_SESSION_SECRET="at_least_32_characters_long"
SANITY_CMS_SESSION_MAX_AGE=604800
SANITY_CMS_REMEMBER_MAX_AGE=2592000

# --- 🔴 TESTING & E2E CONFIGURATION ---
# Used for Playwright or Cypress tests.
BASE_URL= # For overriding site base URL
TEST_USER_EMAIL="test@example.com"
TEST_USER_PASSWORD=
TEST_ENV=
